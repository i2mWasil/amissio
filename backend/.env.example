# ════════════════════════════════════════════════════
# Amissio — Multimodal RAG API Configuration
# ════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.

# ── Google Gemini (required) ──
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_EMBEDDING_DIMENSION=768
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_TEMPERATURE=0.3
GEMINI_REQUESTS_PER_MINUTE=15
GEMINI_MAX_CONCURRENT=5

# ── Qdrant Vector Database ──
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=amissio_chunks
QDRANT_TIMEOUT=30

# ── Whisper (faster-whisper) ──
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
WHISPER_BEAM_SIZE=5

# ── Video / Audio Processing ──
DOWNLOAD_DIR=./data/downloads
FRAMES_DIR=./data/frames
CACHE_DIR=./data/cache
MAX_VIDEO_DURATION_SECONDS=14400
FRAME_EXTRACTION_FPS=1.0
FRAME_HASH_THRESHOLD=8
FRAME_MAX_DIMENSION=1280
AUDIO_FORMAT=wav

# ── Semantic Chunking ──
CHUNK_MIN_TOKENS=500
CHUNK_MAX_TOKENS=1200
CHUNK_OVERLAP_TOKENS=50
SIMILARITY_THRESHOLD=0.75

# ── Retry / Resilience ──
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_DELAY=1.0
RETRY_MAX_DELAY=60.0
RETRY_EXPONENTIAL_BASE=2.0

# ── Map-Reduce / Hierarchical Summarization ──
SEGMENT_DURATION_SECONDS=600
MERGE_BATCH_SIZE=5
MAX_PARALLEL_SEGMENTS=4

# ── Vision / OCR Batching ──
VISION_BATCH_SIZE=5
VISION_MAX_CONCURRENT=3
